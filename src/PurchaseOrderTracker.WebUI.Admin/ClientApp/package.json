{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "homepage": "/admin",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.25",
    "@fortawesome/free-solid-svg-icons": "^5.11.2",
    "@fortawesome/react-fontawesome": "^0.1.5",
    "@types/jest": "24.0.18",
    "@types/node": "12.7.8",
    "@types/react": "16.9.3",
    "@types/react-dom": "16.9.1",
    "dayjs": "^1.10.6",
    "react": "^16.10.1",
    "react-dom": "^16.10.1",
    "react-scripts": "4.0.3",
    "reactstrap": "^8.9.0",
    "typescript": "^4.1.3"
  },
  "scripts": {
    "start": "set SASS_PATH=./node_modules/bootstrap/scss;./src && react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "prettier"
    ],
    "rules": {
      "sort-imports": [
        "error",
        {
          "memberSyntaxSortOrder": [
            "none",
            "all",
            "single",
            "multiple"
          ],
          "allowSeparatedGroups": true
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/reactstrap": "^8.0.4",
    "bootstrap": "^4.3.1",
    "eslint-config-prettier": "^8.3.0",
    "node-sass": "^4.12.0"
  }
}
